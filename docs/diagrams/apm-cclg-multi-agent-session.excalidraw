      "version": 1,
      "versionNonce": 10023,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Boundary rules\\n- APM packages agents and hooks.\\n- CCLG stores source-grounded memory.\\n- Schift Memory syncs CCLG-shaped payloads.\\n- Raw evidence is not automatically active memory.",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 119,
      "containerId": null,
      "originalText": "Boundary rules\\n- APM packages agents and hooks.\\n- CCLG stores source-grounded memory.\\n- Schift Memory syncs CCLG-shaped payloads.\\n- Raw evidence is not automatically active memory.",
      "lineHeight": 1.25
    },
